// ZIGZAG PIVOT DETECTION
// ============================================================================

pivotHigh = ta.pivothigh(high, zigzagLen, zigzagLen)
pivotLow  = ta.pivotlow(low,  zigzagLen, zigzagLen)

var float[] pivotPrices = array.new_float(0)
var int[]   pivotBars   = array.new_int(0)
var int[]   pivotTypes  = array.new_int(0)  // 1 = high, -1 = low

// Add new pivot high
if not na(pivotHigh)
    pivotBar = bar_index - zigzagLen
    canAdd   = array.size(pivotBars) == 0 ? true : (pivotBar - array.get(pivotBars, array.size(pivotBars)-1)) >= minWaveBars
    if canAdd
        lastIsHigh = array.size(pivotTypes) > 0 ? array.get(pivotTypes, array.size(pivotTypes)-1) == 1 : false
        if lastIsHigh
            if pivotHigh > array.get(pivotPrices, array.size(pivotPrices)-1)
                array.set(pivotPrices, array.size(pivotPrices)-1, pivotHigh)
                array.set(pivotBars,   array.size(pivotBars)-1,   pivotBar)
        else
            array.push(pivotPrices, pivotHigh)
            array.push(pivotBars,   pivotBar)
            array.push(pivotTypes,  1)
            if array.size(pivotPrices) > MAX_PIVOTS
                array.shift(pivotPrices)
                array.shift(pivotBars)
                array.shift(pivotTypes)

// Add new pivot low
if not na(pivotLow)
    pivotBar = bar_index - zigzagLen
    canAdd   = array.size(pivotBars) == 0 ? true : (pivotBar - array.get(pivotBars, array.size(pivotBars)-1)) >= minWaveBars
    if canAdd
        lastIsLow = array.size(pivotTypes) > 0 ? array.get(pivotTypes, array.size(pivotTypes)-1) == -1 : false
        if lastIsLow
            if pivotLow < array.get(pivotPrices, array.size(pivotPrices)-1)
                array.set(pivotPrices, array.size(pivotPrices)-1, pivotLow)
                array.set(pivotBars,   array.size(pivotBars)-1,   pivotBar)
        else
            array.push(pivotPrices, pivotLow)
            array.push(pivotBars,   pivotBar)
            array.push(pivotTypes,  -1)
            if array.size(pivotPrices) > MAX_PIVOTS
                array.shift(pivotPrices)
                array.shift(pivotBars)
                array.shift(pivotTypes)

// ============================================================================
// STRICT ELLIOTT WAVE RULE VALIDATION
// ============================================================================

// @function Validate 8 core Elliott Wave rules and return a compliance score.
// @param bull  true = bullish impulse, false = bearish impulse
// @param p0    Wave origin price
// @param p1-p5 Wave 1-5 endpoint prices
// @returns     [complianceScore (0-100), violationCount (0-8)]
validateElliotRules(bull, p0, p1, p2, p3, p4, p5) =>
    violations = 0
    totalRules = 8
    if bull
        w1Len = p1 - p0
        w3Len = p3 - p2
        w5Len = p5 - p4
        // R1: Wave 2 never retraces beyond Wave 1 start
        if p2 <= p0
            violations += 1
        // R2: Wave 3 must advance beyond Wave 1 high
        if p3 <= p1
            violations += 1
        // R3: Wave 3 is never the shortest impulse wave
        if not (w3Len >= w1Len and w3Len >= w5Len)
            violations += 1
        // R4: Wave 4 never overlaps into Wave 1 territory
        if p4 <= p1
            violations += 1
        // R5: Wave 5 advances beyond Wave 3 (allow up to 1% truncation)
        if p5 < p3 * 0.99
            violations += 1
        // R6: Wave 2 retracement within accepted Fibonacci range
        w2Ret = w1Len > 0 ? (p1 - p2) / w1Len : 0.0
        if not (w2Ret >= w2RetLow and w2Ret <= w2RetHigh)
            violations += 1
        // R7: Wave 4 retracement within accepted Fibonacci range
        w4Ret = w3Len > 0 ? (p3 - p4) / w3Len : 0.0
        if not (w4Ret >= w4RetLow and w4Ret <= w4RetHigh)
            violations += 1
        // R8: Wave 3 extension meets minimum threshold
        w3Ext = w1Len > 0 ? w3Len / w1Len : 0.0
        if w3Ext < w3ExtMin
            violations += 1
    else
        w1Len = p0 - p1
        w3Len = p2 - p3
        w5Len = p4 - p5
        if p2 >= p0
            violations += 1
        if p3 >= p1
            violations += 1
        if not (w3Len >= w1Len and w3Len >= w5Len)
            violations += 1
        if p4 >= p1
            violations += 1
        if p5 > p3 * 1.01
            violations += 1
        w2Ret = w1Len > 0 ? (p2 - p1) / w1Len : 0.0
        if not (w2Ret >= w2RetLow and w2Ret <= w2RetHigh)
            violations += 1
        w4Ret = w3Len > 0 ? (p4 - p3) / w3Len : 0.0
        if not (w4Ret >= w4RetLow and w4Ret <= w4RetHigh)
            violations += 1
        w3Ext = w1Len > 0 ? w3Len / w1Len : 0.0
        if w3Ext < w3ExtMin
            violations += 1
    complianceScore = math.round((totalRules - violations) * 100 / totalRules)
    [complianceScore, violations]


// ╚═══════════════════════════════════════════════════════════════════════╝

valid_order = f_check_levels_validity()

// Entry zone boundaries (derived from key levels + offset)
bull_entry_low  = zero_gamma + entry_zone_offset
bull_entry_high = res_mid    - entry_zone_offset
bear_entry_low  = sup_mid   + entry_zone_offset
bear_entry_high = zero_gamma - entry_zone_offset

valid_zones = bull_entry_low < bull_entry_high and bear_entry_low < bear_entry_high
valid_setup = valid_order and valid_zones

// Confirm TF ≥ chart TF (lower confirmation TF is meaningless)
confirm_tf_sec = str.tonumber(confirm_tf) * 60
chart_tf_sec   = timeframe.in_seconds()
tf_is_valid    = not na(confirm_tf_sec) and confirm_tf_sec >= chart_tf_sec

// Warning label (stored in var to prevent accumulation)
var label lbl_warning = na
if barstate.islast
    if not na(lbl_warning)
        label.delete(lbl_warning)
    if not valid_order
        lbl_warning := label.new(bar_index, high,
             '⚠️ Level order invalid: SL < SM < ZG < RM < RH',
             color = color.red, textcolor = color.white,
             size = size.large, style = label.style_label_down)
    else if not valid_zones
        lbl_warning := label.new(bar_index, high,
             '⚠️ Entry Zone Offset too large — zones overlap',
             color = color.orange, textcolor = color.white,
             size = size.large, style = label.style_label_down)
    else if not tf_is_valid
        lbl_warning := label.new(bar_index, high,
             '⚠️ Confirm TF (' + confirm_tf + 'm) < chart TF',
             color = color.yellow, textcolor = color.black,
             size = size.normal, style = label.style_label_down)


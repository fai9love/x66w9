// @function  f_check_levels_validity
// @desc      Validates that all five key levels are in strict ascending order.
// @returns   bool — true if SL < SM < ZG < RM < RH
f_check_levels_validity() =>
    sup_low < sup_mid and sup_mid < zero_gamma and zero_gamma < res_mid and res_mid < res_high

// @function  f_get_position
// @desc      Maps a position string input to the corresponding Pine position constant.
// @param     pos  string — One of: 'top_left', 'top_right', 'bottom_left', 'bottom_right', 'middle_left', 'middle_right'
// @returns   series string (position constant)
f_get_position(pos) =>
    switch pos
        'top_left'     => position.top_left
        'bottom_left'  => position.bottom_left
        'bottom_right' => position.bottom_right
        'middle_left'  => position.middle_left
        'middle_right' => position.middle_right
        => position.top_right

// @function  f_get_size
// @desc      Maps a size string input to the corresponding Pine size constant.
// @param     s  string — One of: 'tiny', 'small', 'normal', 'large', 'huge'
// @returns   series string (size constant)
f_get_size(s) =>
    switch s
        'tiny'  => size.tiny
        'small' => size.small
        'large' => size.large
        'huge'  => size.huge
        => size.normal

// @function  f_levels_overlap
// @desc      Returns true if two price levels are within merge_ticks of each other (visually merged).
// @param     a  float — First price level
// @param     b  float — Second price level
// @returns   bool
f_levels_overlap(a, b) =>
    math.abs(a - b) <= merge_ticks * syminfo.mintick

// @function  f_clamp
// @desc      Clamps a value between a lower and upper bound.
// @param     val  float — Input value
// @param     lo   float — Lower bound
// @param     hi   float — Upper bound
// @returns   float
f_clamp(val, lo, hi) =>
    math.max(lo, math.min(val, hi))

// @function  f_nz
// @desc      Returns fallback if val is na, otherwise returns val. Safe na-replacement.
// @param     val       float — Value to check
// @param     fallback  float — Value to return if val is na
// @returns   float
f_nz(val, fallback) =>
    na(val) ? fallback : val

// @function  f_delete_label
// @desc      Deletes a label if not na. No-op if na.
// @param     lbl  label — Label to delete
f_delete_label(lbl) =>
    if not na(lbl)
        label.delete(lbl)

// @function  f_delete_line
// @desc      Deletes a line if not na. No-op if na.
// @param     ln  line — Line to delete
f_delete_line(ln) =>
    if not na(ln)
        line.delete(ln)

// @function  f_send_alert
// @desc      Dispatches an alert at the user-configured frequency.
//            Frequency options: 'all', 'once_per_bar', 'once_per_bar_close'.
// @param     _msg  string — The alert message to send.
f_send_alert(_msg) =>
    if alert_frequency == 'all'
        alert(_msg, alert.freq_all)
    else if alert_frequency == 'once_per_bar'
        alert(_msg, alert.freq_once_per_bar)
    else
        alert(_msg, alert.freq_once_per_bar_close)

